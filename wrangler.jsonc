{
  "name": "literary-club-app",
  "type": "javascript",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-21",
  "env": {
    "production": {
      "name": "literary-club-app-prod"
    }
  },
  "build": {
    "command": "npm run build",
    "cwd": "./",
    "watch_paths": ["**/*.{ts,tsx,js,jsx,json}"]
  },
  "observability": {
    "enabled": true
  }
}
